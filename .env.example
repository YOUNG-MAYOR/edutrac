# ============================================================
# EduTrack NG — Environment Configuration
# ============================================================
# IMPORTANT: This file is a TEMPLATE. Never commit actual secrets!
#
# For local development:
#   1. Copy this file: cp .env.example .env.local
#   2. Fill in real values from your Supabase dashboard
#   3. Add .env.local to .gitignore (already done)
#
# For Netlify deployment:
#   1. Go to Site settings → Build & deploy → Environment
#   2. Add these variables with real values
#   3. They will NOT appear in git history
#
# For GitHub CI/CD:
#   1. Go to Settings → Secrets and variables → Actions
#   2. Add these as repository secrets
# ============================================================

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/[project-id]/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: Supabase Service Role Key (for server-side operations only!)
# NEVER expose this in browser code
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Application Environment
VITE_APP_MODE=development
# Options: development | staging | production

# Optional: API Base URL (if using separate backend)
VITE_API_BASE_URL=https://api.yourdomain.com

# Optional: Application Analytics
VITE_ANALYTICS_ID=UA-XXXXXXXXX-X
