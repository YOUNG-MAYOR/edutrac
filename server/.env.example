# ── Server ────────────────────────────────────────────────────────
# Railway sets PORT automatically — do not override it in Railway env vars.
PORT=5000

# Netlify frontend URL — used to restrict CORS in production.
# Comma-separate multiple origins if needed.
# Example: https://edutrac.netlify.app,https://yourdomain.com
CLIENT_ORIGIN=https://YOUR_NETLIFY_URL.netlify.app

# ── Supabase ──────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Anthropic (AI Chat proxy) ─────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── OpenAI (Lesson generator) ─────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
