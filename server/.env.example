# ── Server ────────────────────────────────────────────────────────
PORT=5000

# Comma-separated list of allowed client origins (leave blank for dev)
# CLIENT_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# ── Supabase ──────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...  # service_role key — NEVER expose to browser

# ── Anthropic (AI Chat proxy) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI (Lesson generator) ─────────────────────────────────────
OPENAI_API_KEY=sk-...
